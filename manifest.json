{
    "manifest_version": 3,
    "name": "Mindful YouTube Browsing",
    "version": "0.2.1",
    "description": "",

    "icons": {
        "48": "icons/logo.png"
    },
    "action": {
        "default_icon": "icons/logo.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "aeaefaehea@aeheaheaearewqe2.com"
        }
    },
    "background": {
        "scripts": ["background.js"],
        "type": "module"
    },
    "options_page": "src/options/options.html",
    "options_ui": {
        "page": "src/options/options.html"
    },
    "permissions": ["activeTab", "notifications", "storage", "webRequest", "webRequestBlocking"],
    "host_permissions": ["<all_urls>"],
    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["src/constants.js", "src/overlay.js", "src/messages.js", "src/content.js"]
        }
    ]
}
